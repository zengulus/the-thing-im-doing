{
  "schemaVersion": 1,
  "behaviors": [
    {
      "id": "behavior.clause.aim_at_target",
      "steps": [
        { "id": 1, "op": "focus.selected_target" }
      ]
    },
    {
      "id": "behavior.clause.aim_at_nearest_foe",
      "steps": [
        { "id": 1, "op": "focus.nearest_actor", "relation": "hostile" }
      ]
    },
    {
      "id": "behavior.clause.if_marked",
      "steps": [
        { "id": 1, "op": "effect.has", "target": "focus", "source": "caster", "effect": "condition.marked" }
      ]
    },
    {
      "id": "behavior.clause.if_occupied",
      "steps": [
        { "id": 1, "op": "branch.occupied", "target": "focus" }
      ]
    },
    {
      "id": "behavior.clause.if_clear",
      "steps": [
        { "id": 1, "op": "branch.clear", "target": "focus.tile" }
      ]
    },
    {
      "id": "behavior.clause.mark_them",
      "steps": [
        { "id": 1, "op": "effect.attach", "target": "focus", "source": "caster", "effect": "condition.marked" }
      ]
    },
    {
      "id": "behavior.clause.damage_them",
      "steps": [
        { "id": 1, "op": "damage.apply", "target": "focus.actor", "amount": 1 }
      ]
