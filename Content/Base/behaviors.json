        { "id": 1, "op": "counter.add", "target": "focus.actor", "counter": "counter.bonus.charge", "amount": 1 }
      ]
    },
    {
      "id": "behavior.clause.add_lightning_ward",
      "steps": [
        { "id": 1, "op": "effect.attach", "target": "focus.actor", "source": "self", "effect": "effect.ward", "amount": 1 }
      ]
    },
    {
      "id": "behavior.clause.spend_focus",
      "steps": [
        { "id": 1, "op": "counter.consume", "target": "caster", "counter": "counter.bonus.focus", "amount": 1 }
      ]
    },
    {
      "id": "behavior.clause.spend_memory",
      "steps": [
        { "id": 1, "op": "counter.consume", "target": "caster", "counter": "counter.bonus.memory", "amount": 1 }
      ]
    },
    {
