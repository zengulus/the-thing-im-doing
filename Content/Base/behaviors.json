      "id": "behavior.clause.focus_memory_ref",
      "steps": [
        { "id": 1, "op": "focus.ref", "ref": "ref.memory.primary" }
      ]
    },
    {
      "id": "behavior.enemy.glass_hound_turn",
      "steps": [
        { "id": 1, "op": "focus.nearest_actor", "relation": "hostile", "next": 2 },
        { "id": 2, "op": "branch.adjacent", "source": "self", "target": "focus.actor", "true": 3, "false": 4 },
        { "id": 3, "op": "damage.apply", "target": "focus.actor", "amount": 1, "next": 5 },
        { "id": 4, "op": "move.step_toward", "target": "self", "source": "focus.tile", "next": 5 },
        { "id": 5, "op": "flow.stop" }
      ]
    },
    {
      "id": "behavior.enemy.ash_scribe_turn",
      "steps": [
        { "id": 1, "op": "counter.add", "target": "self", "counter": "counter.ai.charge", "amount": 1 },
        { "id": 2, "op": "counter.at_least", "target": "self", "counter": "counter.ai.charge", "amount": 3, "true": 3, "false": 6 },
        { "id": 3, "op": "effect.damage_actors_on_owned_tiles", "effect": "condition.marked", "amount": 1 },
        { "id": 4, "op": "effect.clear_owned_tiles", "effect": "condition.marked", "next": 5 },
        { "id": 5, "op": "counter.consume", "target": "self", "counter": "counter.ai.charge", "amount": 3, "next": 8 },
        { "id": 6, "op": "focus.nearest_actor", "relation": "hostile", "next": 7 },
        { "id": 7, "op": "effect.attach", "target": "focus.tile", "source": "self", "effect": "condition.marked", "next": 8 },
        { "id": 8, "op": "flow.stop" }
      ]
    },
    {
      "id": "behavior.enemy.root_saint_turn",
      "steps": [
        { "id": 1, "op": "branch.adjacent_blocking", "target": "self", "true": 2, "false": 3 },
        { "id": 2, "op": "heal.apply", "target": "self", "amount": 1, "next": 3 },
        { "id": 3, "op": "tile.set_first_adjacent_clear_state", "target": "self", "state": "RaisedStone" }
      ]
    },
    {
      "id": "behavior.rule.brittle_stone_push_collision",
      "steps": [
        { "id": 1, "op": "branch.tile_state", "target": "event.tile", "state": "RaisedStone", "true": 2 },
        { "id": 2, "op": "tile.set_state", "target": "event.tile", "state": "Floor" },
        { "id": 3, "op": "damage.apply", "target": "event.actor", "amount": 1 }
      ]
    },
    {
      "id": "behavior.effect.poison_turn_start",
      "steps": [
        { "id": 1, "op": "damage.apply", "target": "event.actor", "amount": 1, "next": 2 },
        { "id": 2, "op": "counter.consume", "target": "effect", "counter": "counter.stack", "amount": 1, "true": 3, "false": 4 },
        { "id": 3, "op": "counter.at_least", "target": "effect", "counter": "counter.stack", "amount": 1, "true": 5, "false": 4 },
        { "id": 4, "op": "effect.detach", "target": "effect", "source": "effect.target", "next": 5 },
        { "id": 5, "op": "flow.stop" }
      ]
    },
    {
      "id": "behavior.effect.bleed_move",
      "steps": [
        { "id": 1, "op": "damage.apply", "target": "event.actor", "source": "effect", "counter": "counter.stack" }
      ]
    },
    {
      "id": "behavior.effect.lightning_shield_adjacent",
      "steps": [
        { "id": 1, "op": "branch.relation", "source": "effect.target", "target": "event.actor", "relation": "hostile", "true": 2, "false": 7 },
        { "id": 2, "op": "counter.at_least", "target": "effect.target", "counter": "counter.bonus.charge", "amount": 1, "true": 3, "false": 6 },
        { "id": 3, "op": "damage.apply", "target": "event.actor", "source": "effect.target", "counter": "counter.bonus.charge", "next": 4 },
        { "id": 4, "op": "counter.consume", "target": "effect.target", "counter": "counter.bonus.charge", "amount": 1, "true": 5, "false": 6 },
        { "id": 5, "op": "counter.at_least", "target": "effect.target", "counter": "counter.bonus.charge", "amount": 1, "true": 7, "false": 6 },
        { "id": 6, "op": "effect.detach", "target": "effect", "source": "effect.target", "next": 7 },
        { "id": 7, "op": "flow.stop" }
      ]
    },
    {
      "id": "behavior.effect.ward_before_damage",
      "steps": [
        { "id": 1, "op": "counter.at_least", "target": "effect", "counter": "counter.stack", "amount": 1, "true": 2, "false": 5 },
        { "id": 2, "op": "damage.prevent_event", "next": 3 },
        { "id": 3, "op": "counter.consume", "target": "effect", "counter": "counter.stack", "amount": 1, "true": 4, "false": 5 },
        { "id": 4, "op": "counter.at_least", "target": "effect", "counter": "counter.stack", "amount": 1, "true": 6, "false": 5 },
        { "id": 5, "op": "effect.detach", "target": "effect", "source": "effect.target", "next": 6 },
        { "id": 6, "op": "flow.stop" }
      ]
    },
    {
      "id": "behavior.relic.patient_bell_after_spell",
      "steps": [
        { "id": 1, "op": "counter.add", "target": "event.actor", "counter": "counter.bonus.focus", "amount": 1, "next": 2 },
        { "id": 2, "op": "flow.stop" }
      ]
    }
  ]
}
