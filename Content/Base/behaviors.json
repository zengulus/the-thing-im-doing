      "steps": [
        { "id": 1, "op": "tile.set_state", "target": "focus.tile", "state": "RaisedStone" }
      ]
    },
    {
      "id": "behavior.clause.push_them",
      "steps": [
        { "id": 1, "op": "move.relative", "target": "focus.actor", "source": "self", "mode": "away", "amount": 1 }
      ]
    },
    {
      "id": "behavior.clause.poison_them",
      "steps": [
        { "id": 1, "op": "effect.attach", "target": "focus.actor", "source": "self", "effect": "effect.poison", "amount": 3 }
      ]
    },
    {
      "id": "behavior.clause.bleed_them",
      "steps": [
        { "id": 1, "op": "effect.attach", "target": "focus.actor", "source": "self", "effect": "effect.bleed", "amount": 1 }
      ]
    },
    {
      "id": "behavior.clause.spend_poison",
      "steps": [
        { "id": 1, "op": "counter.consume", "target": "focus.effect", "effect": "effect.poison", "counter": "counter.stack", "amount": 1 }
      ]
    },
    {
      "id": "behavior.clause.spend_bleed",
      "steps": [
        { "id": 1, "op": "counter.consume", "target": "focus.effect", "effect": "effect.bleed", "counter": "counter.stack", "amount": 1 }
      ]
    },
    {
      "id": "behavior.clause.lightning_shield",
